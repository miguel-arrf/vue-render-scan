{
  "name": "vue-render-scan",
  "version": "0.1.0",
  "description": "Visualize Vue component rerenders in development.",
  "type": "module",
  "license": "MIT",
  "author": "Miguel Ferreira",
  "homepage": "https://github.com/miguel-arrf/vue-render-scan#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miguel-arrf/vue-render-scan.git"
  },
  "bugs": {
    "url": "https://github.com/miguel-arrf/vue-render-scan/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "render",
    "rerender",
    "performance",
    "debugging",
    "devtools"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt/module.d.ts",
      "import": "./dist/nuxt/module.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "playground": "vite --host 127.0.0.1 playground",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.12.0 || ^4.0.0",
    "nuxt": "^3.12.0 || ^4.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/kit": "^3.12.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "jsdom": "^25.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
